NODE_ENV=development
PORT=3001

# PostgreSQL + TimescaleDB
DATABASE_URL=postgresql://soar_user:sifre@localhost:5432/soar_db

# Redis
REDIS_URL=redis://:sifre@localhost:6379

# JWT (openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AES-256 encryption (openssl rand -hex 32 - tam 64 hex karakter)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# VirusTotal (isteğe bağlı, kullanıcı UI'dan da girebilir)
VIRUSTOTAL_API_KEY=
